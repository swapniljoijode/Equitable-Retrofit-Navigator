project_name          = "equitable-retrofit-navigator"
aws_region            = "us-east-1"
container_image       = "123456789012.dkr.ecr.us-east-1.amazonaws.com/equitable-retrofit-navigator:latest"
vpc_id                = "vpc-xxxxxxxx"
public_subnet_ids     = ["subnet-public-a", "subnet-public-b"]
private_subnet_ids    = ["subnet-aaaa", "subnet-bbbb"]
ecs_security_group_id = "sg-xxxxxxxx"
alb_security_group_id = "sg-yyyyyyyy"
certificate_arn       = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
desired_count         = 1
min_capacity          = 1
max_capacity          = 4
cpu                   = 512
memory                = 1024
api_auth_key          = "replace-with-strong-key"
openai_api_key        = "sk-..."
google_api_key        = "..."
nyc_open_data_app_token = ""
enable_waf            = true
